# --- Base de données PostgreSQL (installée sur l'hôte) ---
# IP du gateway Docker bridge (172.17.0.1 par défaut)
# Identifier avec: docker network inspect bridge | grep Gateway
DATABASE_HOST=172.17.0.1
DATABASE_PORT=5432
DATABASE_NAME=gesy
DATABASE_USER=gesy
DATABASE_PASSWORD=@sdjFDDR!29dhdxwvq5

# --- Traefik & Domaines ---
# Domaine principal (frontend: https://sfb-petroleum.net)
DOMAIN=sfb-petroleum.net
# Email pour Let's Encrypt (certificats HTTPS)
ACME_EMAIL=admin@sfb-petroleum.net

# --- Frontend ---
# URL de l'API (build-time) - accessible depuis le navigateur
# Prod: https://api.sfb-petroleum.net/api
API_URL=https://api.sfb-petroleum.net/api

# --- Mail SMTP/IMAP (pour envoi/réception d'emails) ---
MAIL_HOST=mail.sfb-petroleum.com
MAIL_PORT=465
MAIL_USERNAME=oumar.sanogo@sfb-petroleum.com
MAIL_PASSWORD=oumar@123
MAIL_PROTOCOL=smtps
MAIL_DEBUG=false

# SMTP auth / chiffrement (Spring mail.smtp.*)
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_STARTTLS_REQUIRED=false
MAIL_SMTP_SSL_ENABLE=true
# Hôte(s) ou motif de confiance SSL (évite "Server is not trusted"). Souvent = MAIL_HOST ; sinon "*" (moins sûr).
MAIL_SMTP_SSL_TRUST=mail.sfb-petroleum.com

# SMTPS (Spring mail.smtps.*) — port 465 / protocol smtps
MAIL_SMTPS_AUTH=true
MAIL_SMTPS_SSL_ENABLE=true
MAIL_SMTPS_SSL_TRUST=mail.sfb-petroleum.com
# Vérification stricte du nom d’hôte du certificat (true = plus strict). Défaut côté appli : false.
# MAIL_SMTP_SSL_CHECK_SERVER_IDENTITY=false
# MAIL_SMTPS_SSL_CHECK_SERVER_IDENTITY=false
# En dernier recours si le certificat reste refusé : remplacer les *_SSL_TRUST par * (accepte tout — risque sécurité).

# IMAP (réception)
MAIL_IMAP_HOST=mail.sfb-petroleum.com
MAIL_IMAP_PORT=993

# --- Optionnel ---
TZ=UTC
